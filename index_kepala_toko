// ── Filter Periode ────────────────────────────────────────
$bulan = (int)($_GET['bulan'] ?? date('m'));
$tahun = (int)($_GET['tahun'] ?? date('Y'));
if ($bulan < 1 || $bulan > 12) $bulan = (int)date('m');
if ($tahun < 2020 || $tahun > 2099) $tahun = (int)date('Y');
$periodeStart = sprintf('%04d-%02d-01', $tahun, $bulan);
$periodeEnd   = date('Y-m-t', strtotime($periodeStart));

// ── Query Ringkasan ───────────────────────────────────────
$revenueBulanIni = $conn->query(
    "SELECT COALESCE(SUM(total_harga),0) AS r FROM pesanan
     WHERE status_bayar='Selesai' AND DATE(tanggal) BETWEEN '$periodeStart' AND '$periodeEnd'"
)->fetch_assoc()['r'];

$jmlPesananBulan = $conn->query(
    "SELECT COUNT(*) AS c FROM pesanan WHERE DATE(tanggal) BETWEEN '$periodeStart' AND '$periodeEnd'"
)->fetch_assoc()['c'];

$jmlSelesai = $conn->query(
    "SELECT COUNT(*) AS c FROM pesanan WHERE status_bayar='Selesai' AND DATE(tanggal) BETWEEN '$periodeStart' AND '$periodeEnd'"
)->fetch_assoc()['c'];

$jmlProses = $conn->query(
    "SELECT COUNT(*) AS c FROM pesanan WHERE status_bayar IN ('Diproses','Dikirim') AND DATE(tanggal) BETWEEN '$periodeStart' AND '$periodeEnd'"
)->fetch_assoc()['c'];

// ── Produk Terlaris ────────────────────────────────────────
$terlaris = $conn->query(
    "SELECT p.nama_produk, SUM(dp.jumlah) AS total_terjual, SUM(dp.subtotal) AS total_omzet
     FROM detail_pesanan dp
     JOIN produk p ON p.id = dp.id_produk
     JOIN pesanan ps ON ps.id_pesanan = dp.id_pesanan
     WHERE ps.status_bayar = 'Selesai' AND DATE(ps.tanggal) BETWEEN '$periodeStart' AND '$periodeEnd'
     GROUP BY dp.id_produk ORDER BY total_terjual DESC LIMIT 8"
);

// ── Revenue Harian (untuk grafik) ─────────────────────────
$revHarian = $conn->query(
    "SELECT DATE(tanggal) AS tgl, COALESCE(SUM(total_harga),0) AS rev
     FROM pesanan WHERE status_bayar='Selesai'
     AND DATE(tanggal) BETWEEN '$periodeStart' AND '$periodeEnd'
     GROUP BY DATE(tanggal) ORDER BY tgl ASC"
);
$chartLabels = []; $chartData = [];
while ($r = $revHarian->fetch_assoc()) {
    $chartLabels[] = date('d', strtotime($r['tgl']));
    $chartData[]   = (float)$r['rev'];
}

// ── Rekap Semua Status ─────────────────────────────────────
$rekapStatus = $conn->query(
    "SELECT status_bayar, COUNT(*) AS jumlah, COALESCE(SUM(total_harga),0) AS total
     FROM pesanan WHERE DATE(tanggal) BETWEEN '$periodeStart' AND '$periodeEnd'
     GROUP BY status_bayar ORDER BY FIELD(status_bayar,'Selesai','Dikirim','Diproses','Menunggu Pembayaran','Dibatalkan')"
);

$namaBulan = ['','Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
